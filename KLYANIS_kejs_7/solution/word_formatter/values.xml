      <value name="INPUT_PATH">
        <shadow type="text">
          <field name="TEXT">C:\test\input.docx</field>
        </shadow>
      </value>
      <value name="OUTPUT_PATH">
        <shadow type="text">
          <field name="TEXT">C:\test\output.docx</field>
        </shadow>
      </value>
      <value name="FONT_NAME">
        <shadow type="text">
          <field name="TEXT">Calibri</field>
        </shadow>
      </value>
      <value name="FONT_SIZE">
        <shadow type="math_number">
          <field name="NUM">12</field>
        </shadow>
      </value>
      <value name="REPLACEMENTS">
        <shadow type="text">
          <field name="TEXT">{}</field>
        </shadow>
      </value>
    </block>
  </category>
</category>
