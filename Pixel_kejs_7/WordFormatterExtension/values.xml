<block type="WordFormatterExtension">
    <value name="SOURCE_PATH">
        <shadow type="text">
            <field name="TEXT">C:\\document.docx</field>
        </shadow>
    </value>
    <value name="OUTPUT_PATH">
        <shadow type="text">
            <field name="TEXT">C:\\document_formatted.docx</field>
        </shadow>
    </value>
    <value name="FONT_NAME">
        <shadow type="text">
            <field name="TEXT">Times New Roman</field>
        </shadow>
    </value>
    <value name="FONT_SIZE">
        <shadow type="math_number">
            <field name="NUM">14</field>
        </shadow>
    </value>
    <value name="PLACEHOLDERS">
        <shadow type="text">
            <field name="TEXT">{}</field>
        </shadow>
    </value>
</block>